<Window x:Class="ParallelScope.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings" Height="620" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Icon="Assets/logo.ico"
        FontFamily="Segoe UI Variable Text">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: 設定カテゴリのメニュー。選択に応じて右側のパネルを切り替える -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="4" Margin="0,0,10,0">
                <ListBox Name="SettingsMenuListBox" BorderThickness="0" Background="Transparent"
                         SelectionChanged="SettingsMenuListBox_SelectionChanged">
                    <ListBoxItem Content="Root Folders" IsSelected="True" Padding="8,6"/>
                    <ListBoxItem Content="Display Columns" Padding="8,6"/>
                </ListBox>
            </Border>

            <!-- 右側: ルート追加/削除・除外・スキャン間隔のページ -->
            <Grid Grid.Column="1" Name="RootSettingsPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Target Root Folders" Style="{StaticResource PaneHeaderTextStyle}"/>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="8">
                    <ListBox Name="RootPathsListBox"/>
                </Border>

                <Border Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Name="NewRootPathTextBox" Height="28" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="Add" Width="72" Margin="8,0,0,0" Click="AddRootPathButton_Click"/>
                    <Button Grid.Column="2" Content="Remove" Width="72" Margin="8,0,0,0" Click="RemoveRootPathButton_Click"/>
                    <Button Grid.Column="3" Content="↑ Up" Width="60" Margin="8,0,0,0" Click="MoveRootPathUpButton_Click"/>
                    <Button Grid.Column="4" Content="↓ Down" Width="60" Margin="8,0,0,0" Click="MoveRootPathDownButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Auto full scan interval"/>
                    <TextBox Grid.Column="1" Name="FullScanIntervalHoursTextBox" Margin="8,0,8,0" Height="28" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="hours"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4" Text="Excluded Folders" Style="{StaticResource PaneHeaderTextStyle}" Margin="0,12,0,8"/>

                <Border Grid.Row="5" Style="{StaticResource CardBorderStyle}" Padding="8">
                    <ListBox Name="ExcludedPathsListBox"/>
                </Border>

                <Border Grid.Row="6" Margin="0,10,0,0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Name="NewExcludedPathTextBox" Height="28" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Add" Width="72" Margin="8,0,0,0" Click="AddExcludedPathButton_Click"/>
                        <Button Grid.Column="2" Content="Remove" Width="72" Margin="8,0,0,0" Click="RemoveExcludedPathButton_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 右側: ファイル一覧の表示列カスタマイズのページ -->
            <Grid Grid.Column="1" Name="ColumnSettingsPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Display Columns" Style="{StaticResource PaneHeaderTextStyle}"/>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Select the columns to show in the file list." Margin="0,0,0,4"/>
                        <TextBlock Text="The Name column is always shown." Foreground="Gray" Margin="0,0,0,12"/>

                        <!-- 画面上の列順に並べる（FileListColumns.OptionalColumns と同順） -->
                        <CheckBox Name="LocationColumnCheckBox" Content="Location (parent folder path)" Margin="0,4,0,0"/>
                        <CheckBox Name="TypeColumnCheckBox" Content="Type" Margin="0,8,0,0"/>
                        <CheckBox Name="SizeColumnCheckBox" Content="Size" Margin="0,8,0,0"/>
                        <CheckBox Name="ModifiedColumnCheckBox" Content="Modified" Margin="0,8,0,0"/>
                        <CheckBox Name="CreatedColumnCheckBox" Content="Created" Margin="0,8,0,0"/>
                        <CheckBox Name="AttributesColumnCheckBox" Content="Attributes (R/H/S/A)" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <!-- フルスキャンが意味を持つのはルート/除外設定のみのため、Display Columnsページでは非表示にする -->
            <Button Name="SaveAndFullScanButton" Content="Save + Full Scan" Width="130" Margin="0,0,8,0" Click="SaveAndFullScanButton_Click"/>
            <Button Content="Save" Width="90" IsDefault="True" Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
