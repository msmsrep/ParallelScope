<Window x:Class="ParallelFiler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParallelFiler"
        mc:Ignorable="d"
        Title="ParallelFiler" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Menu Grid.Column="0" HorizontalAlignment="Left">
                <MenuItem Header="設定">
                    <MenuItem Header="設定を開く" Click="OpenSettingsMenuItem_Click"/>
                </MenuItem>
            </Menu>

            <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="← 戻る" Width="80" Margin="0,0,6,0" Click="BackButton_Click"
                            IsEnabled="{Binding CanGoBack}"/>
                    <Button Content="進む →" Width="80" Margin="0,0,6,0" Click="ForwardButton_Click"
                            IsEnabled="{Binding CanGoForward}"/>
                    <Button Content="↑ 上へ" Width="80" Click="UpButton_Click"
                            IsEnabled="{Binding CanGoUp}"/>
                </StackPanel>

                <TextBox Grid.Column="1" Text="{Binding AddressInput, UpdateSourceTrigger=PropertyChanged}" Height="28"
                         VerticalContentAlignment="Center" KeyDown="AddressTextBox_KeyDown"/>
            </Grid>
        </Grid>

        <!-- 左側: フォルダツリー -->
        <Grid Grid.Row="1" Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="フォルダ" FontSize="14" FontWeight="Bold" Margin="10,10,10,5"/>
            
            <TreeView Grid.Row="1" Name="FolderTreeView" Margin="10,0,10,10" 
                      ItemsSource="{Binding RootFolders}" 
                      SelectedItemChanged="FolderTreeView_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding SubFolders}">
                        <TextBlock Text="{Binding DisplayName}" Foreground="#333333"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- セパレーター -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" 
                      Background="#CCCCCC" Cursor="SizeWE"/>

        <!-- 右側: ファイル一覧 -->
        <Grid Grid.Row="1" Grid.Column="2" Background="White">
            <DataGrid Grid.Row="0" ItemsSource="{Binding FileItems}" Margin="10,10,10,10"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      MouseDoubleClick="FileListDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ファイル名" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="種類" Binding="{Binding TypeText}" Width="100"/>
                    <DataGridTextColumn Header="サイズ" Binding="{Binding SizeText}" Width="100"/>
                    <DataGridTextColumn Header="更新日時" Binding="{Binding ModifiedTime}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
