<Window x:Class="ParallelScope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParallelScope"
        mc:Ignorable="d"
        Title="ParallelScope" Height="600" Width="1000"
        Icon="Assets/logo.ico"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>

        <Style x:Key="ScanningIndicatorStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="⟳"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="#060a0e"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:0.8"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,8" Style="{StaticResource CardBorderStyle}">
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Menu Grid.Column="0" HorizontalAlignment="Left">
                <MenuItem Header="Menu">
                    <MenuItem Header="⚙  Settings" Click="OpenSettingsMenuItem_Click"/>
                    <MenuItem Header="☕ Support | Buy a coffee for the developer" Click="KofiMenuItem_Click"/>
                    <MenuItem Header="💜 Support | GitHub Sponsors" Click="GitHubSponsorsMenuItem_Click"/>
                </MenuItem>
            </Menu>

            <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="← Back" Width="80" Margin="0,0,6,0" Click="BackButton_Click"
                            IsEnabled="{Binding CanGoBack}"/>
                    <Button Content="Forward →" Width="80" Margin="0,0,6,0" Click="ForwardButton_Click"
                            IsEnabled="{Binding CanGoForward}"/>
                    <Button Content="↑ Up" Width="80" Click="UpButton_Click"
                            IsEnabled="{Binding CanGoUp}"/>
                </StackPanel>

                <TextBox Grid.Column="1" Text="{Binding AddressInput, UpdateSourceTrigger=PropertyChanged}" Height="28"
                         VerticalContentAlignment="Center" KeyDown="AddressTextBox_KeyDown"/>
            </Grid>
            </Grid>
        </Border>

        <!-- 左側: フォルダツリー -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,0">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Folders" Style="{StaticResource PaneHeaderTextStyle}"/>
            
            <!-- 最上位は仮想「Roots」ノードのみで、各ルートはその子として表示される -->
            <TreeView Grid.Row="1" Name="FolderTreeView"
                      ItemsSource="{Binding TreeRoots}"
                      PreviewMouseRightButtonDown="FolderTreeView_PreviewMouseRightButtonDown"
                      SelectedItemChanged="FolderTreeView_SelectedItemChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <EventSetter Event="ContextMenuOpening" Handler="FolderTreeItem_ContextMenuOpening"/>
                        <EventSetter Event="Loaded" Handler="FolderTreeViewItem_Loaded"/>
                        <EventSetter Event="Expanded" Handler="FolderTreeItem_Expanded"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding SubFolders}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Style="{StaticResource ScanningIndicatorStyle}">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="{Binding DisplayName}"/>
                            </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            </Grid>
        </Border>

        <!-- セパレーター -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE"/>

        <!-- 右側: ファイル一覧 -->
        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 入力するたびに SearchQuery が更新され、インクリメンタルサーチが実行される -->
                <TextBox Grid.Column="0" Margin="0,0,8,0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Height="28"
                         VerticalContentAlignment="Center"/>
                <!-- ONのとき、現在フォルダ配下の全ファイルを再帰的に表示する -->
                <ToggleButton Grid.Column="1" Content="All Files" Width="72"
                              IsChecked="{Binding IsFlatFileViewEnabled}"/>
            </Grid>

            <DataGrid Grid.Row="1" Name="FileListDataGrid" ItemsSource="{Binding FileItems}" Margin="0,8,0,0"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      MouseDoubleClick="FileListDataGrid_MouseDoubleClick"
                      PreviewMouseRightButtonDown="FileListDataGrid_PreviewMouseRightButtonDown"
                      ContextMenuOpening="FileListDataGrid_ContextMenuOpening">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy File" Click="CopyFileMenuItem_Click"/>
                        <MenuItem Header="Copy File Name" Click="CopyFileNameMenuItem_Click"/>
                        <MenuItem Header="Copy Full Path" Click="CopyFullPathMenuItem_Click"/>
                        <Separator/>
                        <MenuItem Header="Open Parent Folder" Click="OpenParentFolderMenuItem_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Name" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Name以外の列は設定（Display Columns）で表示/非表示を切り替えられる（ApplyFileListColumnVisibility参照） -->
                    <DataGridTextColumn x:Name="LocationColumn" Header="Location" Binding="{Binding Location}" Width="220"/>
                    <DataGridTextColumn x:Name="TypeColumn" Header="Type" Binding="{Binding TypeText}" Width="110"/>
                    <DataGridTextColumn x:Name="SizeColumn" Header="Size" Binding="{Binding SizeText}" Width="100"/>
                    <DataGridTextColumn x:Name="ModifiedColumn" Header="Modified" Binding="{Binding ModifiedTime}" Width="150"/>
                    <DataGridTextColumn x:Name="CreatedColumn" Header="Created" Binding="{Binding CreatedTime}" Width="150"/>
                    <DataGridTextColumn x:Name="AttributesColumn" Header="Attributes" Binding="{Binding AttributesText}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
